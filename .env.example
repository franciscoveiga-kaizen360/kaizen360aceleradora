# ─── Vercel Postgres (database for quiz responses) ──────────────────────────
# Obtain from Vercel Dashboard → Storage → Postgres → .env.local
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NO_SSL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# ─── Webhook integration (CRM / Make / Zapier / n8n) ────────────────────────
# POST endpoint that receives quiz submission payload
WEBHOOK_URL=

# Optional bearer token for webhook authentication
WEBHOOK_SECRET=

# ─── Google Tag Manager ───────────────────────────────────────────────────────
NEXT_PUBLIC_GTM_ID=

# ─── Site URL (for absolute URLs in metadata) ────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://docsgrowth.com.br
